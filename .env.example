# Reels Analyzer Environment Variables
# Copy to .env and modify as needed.
# pydantic-settings will auto-override YAML config values.

# Pipeline
# REELS_PIPELINE_WORK_DIR=./work
# REELS_PIPELINE_LOG_LEVEL=DEBUG
# REELS_PIPELINE_MAX_VIDEO_DURATION_SEC=600

# Ingest
# REELS_INGEST_STRATEGY=preserve_aspect
# REELS_INGEST_MAX_SHORT_SIDE=1080

# Analysis
# REELS_ANALYSIS_PLACE_MODEL=openai/clip-vit-large-patch14
# REELS_ANALYSIS_SUBTITLE_ENGINE=paddleocr
# REELS_ANALYSIS_SPEECH_MODEL=large-v3
# REELS_ANALYSIS_SPEECH_COMPUTE_TYPE=float16

# Database
# REELS_DB_PATH=./data/templates.db
